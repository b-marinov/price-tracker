# Copy this file to .env.compose and adjust as needed.
# These URLs use Docker Compose service names as hostnames — do NOT use localhost.

# Database — points to the "postgres" service
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/price_tracker

# Redis — points to the "redis" service
REDIS_URL=redis://redis:6379/0

# Application
APP_ENV=development
SECRET_KEY=dev-secret-key-change-in-production
ADMIN_KEY=dev-admin-key-change-in-production

# LLM Parser (Ollama) — set LLM_PARSER_ENABLED=true to activate
# gemma4:e4b = vision model for PDF/screenshot extraction
# qwen3.5:9b = text model for brochure URL discovery (faster, lower VRAM)
LLM_PARSER_ENABLED=false
LLM_OLLAMA_HOST=http://ollama:11434
LLM_MODEL=gemma4:e4b
LLM_TEXT_MODEL=qwen3.5:9b
LLM_PAGE_DPI=200
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=120
