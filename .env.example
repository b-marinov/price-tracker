# ──────────────────────────────────────────────────────────────────────────────
# .env.example — for running the backend directly on your host machine.
# For Docker Compose dev use .env.compose.example instead.
# ──────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/price_tracker

# Redis
REDIS_URL=redis://localhost:6379/0

# Application
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key

# Admin
ADMIN_KEY=change-me-to-a-random-admin-key
